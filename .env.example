# Banco de dados Postgres (ex: Neon — https://neon.tech)
DATABASE_URL="postgresql://usuario:senha@host/banco?sslmode=verify-full"

# Chave da API MiniMax — usada no guia de experiências E no chat (streaming).
# Subscription (Coding Plan) via endpoint Anthropic-compatible.
# https://platform.minimax.io
MINIMAX_API_KEY="sk-api-..."

# Chave do Google Maps Platform (Geocoding + Places API New) — ancora o guia
# em lugares/distâncias reais. Server-side; restrição de aplicativo = Nenhuma.
GOOGLE_API_KEY="AIza..."
